				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const response = pm.response.json();",
									"if (pm.response.code === 200 && response.data && response.data.access_token) {",
									"    pm.collectionVariables.set(\"token\", response.data.access_token);",
									"    console.log(\"JWT Token refreshed and updated in variables.\");",
									"}"
								],
								"type": "javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
